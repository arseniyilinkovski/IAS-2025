<UserControl x:Class="SimpleIDE.Controls.SyntaxHighlightingTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <avalon:TextEditor x:Name="Editor" 
                           FontFamily="Consolas" 
                           FontSize="14"
                           Background="#1E1E1E"
                           Foreground="#D4D4D4"
                           BorderThickness="0"
                           Padding="15,10,15,10"
                           ShowLineNumbers="True"
                           WordWrap="True">
            <avalon:TextEditor.ContextMenu>
                <ContextMenu>
                    <!-- Системные шаблоны -->
                    <MenuItem Header="📝 Вставить шаблон">
                        <MenuItem Header="⭐ main (стандартный)" Click="InsertMainTemplate_Click"/>
                        <MenuItem Header="⭐ main с переменными" Click="InsertMainWithVarTemplate_Click"/>
                        <MenuItem Header="⭐ Функция (пустая)" Click="InsertFunctionTemplate_Click"/>
                        <MenuItem Header="⭐ Цикл repeat" Click="InsertRepeatTemplate_Click"/>
                        <MenuItem Header="⭐ Условный оператор if" Click="InsertIfTemplate_Click"/>
                        <Separator/>

                        <!-- Пользовательские шаблоны -->
                        <MenuItem x:Name="UserTemplatesMenu" Header="🔧 Мои шаблоны"/>
                    </MenuItem>

                    <Separator/>

                    <MenuItem Header="➕ Добавить выделенное как шаблон" Click="AddAsTemplate_Click"/>

                    <MenuItem x:Name="ManageTemplatesMenu" Header="⚙️ Управление шаблонами">
                        <MenuItem Header="📋 Показать все шаблоны" Click="ShowAllTemplates_Click"/>
                        <Separator/>
                        <MenuItem Header="🗑 Очистить мои шаблоны" Click="ClearUserTemplates_Click"/>
                    </MenuItem>

                    <Separator/>

                    <MenuItem Header="📋 Копировать" Click="Copy_Click"/>
                    <MenuItem Header="✂️ Вырезать" Click="Cut_Click"/>
                    <MenuItem Header="📄 Вставить" Click="Paste_Click"/>
                    <Separator/>
                    <MenuItem Header="🗑 Очистить всё" Click="ClearAll_Click"/>
                </ContextMenu>
            </avalon:TextEditor.ContextMenu>
        </avalon:TextEditor>
    </Grid>
</UserControl>