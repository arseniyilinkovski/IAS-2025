<UserControl x:Class="SimpleIDE.Controls.SyntaxHighlightingTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <avalon:TextEditor x:Name="Editor" 
                           FontFamily="Consolas" 
                           FontSize="14"
                           Background="#1E1E1E"
                           Foreground="#D4D4D4"
                           BorderThickness="0"
                           Padding="15,10,15,10"
                           ShowLineNumbers="True"
                           WordWrap="True">
            <avalon:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="📝 Преобразовать в шаблон main" Click="ConvertToMainTemplate_Click">
                        <MenuItem.ToolTip>
                            <ToolTip>Заменяет весь код на шаблон main с выводом "Hello World"</ToolTip>
                        </MenuItem.ToolTip>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="📋 Копировать" Click="Copy_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="✂️ Вырезать" Click="Cut_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="✂️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="📄 Вставить" Click="Paste_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📄" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="🗑 Очистить всё" Click="ClearAll_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🗑" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </avalon:TextEditor.ContextMenu>
        </avalon:TextEditor>
    </Grid>
</UserControl>