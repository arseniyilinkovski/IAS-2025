<Window x:Class="SimpleIDE.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод" Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Text="Введите значение:" FontSize="14" Margin="0,0,0,10"/>

        <PasswordBox x:Name="PasswordInput" Grid.Row="1" Height="35" Visibility="Collapsed"/>
        <TextBox x:Name="TextInput" Grid.Row="1" Height="35" Visibility="Visible"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Height="35" Margin="0,0,10,0" 
                    Background="#6C63FF" Foreground="White" Click="Ok_Click"/>
            <Button Content="Отмена" Width="80" Height="35" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>