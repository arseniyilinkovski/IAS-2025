<Window x:Class="SimpleIDE.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SimpleIDE.Controls"
        Title="SimpleIDE - IAS-2025" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDark}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - файловый менеджер -->
        <Border Grid.Column="0" Background="{StaticResource BackgroundLight}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource BackgroundPanel}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Мои проекты" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextLight}"/>
                        <TextBlock Text="Правой кнопкой мыши для создания" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <TreeView x:Name="FileTreeView" Background="{StaticResource BackgroundLight}" BorderThickness="0" Margin="0,10,5,0">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="📁 Создать папку" Click="CreateRootFolder_Click"/>
                            <MenuItem Header="📄 Создать файл" Click="CreateRootFile_Click"/>
                            <Separator/>
                            <MenuItem Header="🔄 Обновить" Click="Refresh_Click"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- Правая панель - редактор и вывод -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="300"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель инструментов -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundMedium}" Padding="10" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая группа - кнопки -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="▶ Запустить" Background="{StaticResource AccentColor}" 
                                Style="{StaticResource ModernButton}" Click="RunCode_Click"/>
                        <Button Content="📋 Пример" Background="{StaticResource WarningColor}" 
                                Style="{StaticResource ModernButton}" Click="LoadExample_Click" Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- Центр - информация о файле -->
                    <TextBlock Grid.Column="1" x:Name="FileInfoText" 
                               Text="Нет открытого файла" 
                               Foreground="{StaticResource TextSecondary}" 
                               VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>

                    <!-- Правая группа - пользователь и кнопки -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Упрощенный бейдж пользователя (только визуал, без функционала) -->
                        <Border Style="{StaticResource UserBadgeStyle}">
                            <StackPanel Orientation="Horizontal">
                                <!-- Аватар -->
                                <Border Style="{StaticResource AvatarStyle}">
                                    <TextBlock x:Name="AvatarText" Text="👤" FontSize="16" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- Информация -->
                                <StackPanel>
                                    <TextBlock x:Name="UserNameText" Text="" FontSize="12" 
                           Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="UserRoleText" Text="" FontSize="10" 
                           Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Кнопки действий -->
                        <Button x:Name="AdminButton" Content="👑 Стать администратором" 
            Background="{StaticResource WarningColor}" Style="{StaticResource ModernButton}" 
            Click="BecomeAdmin_Click" Visibility="Collapsed"/>
                        <Button x:Name="UserManagementButton" Content="👥 Пользователи" 
            Background="#2196F3" Style="{StaticResource ModernButton}" 
            Click="UserManagement_Click" Visibility="Collapsed"/>
                        <Button Content="🔄 Обновить" Background="{StaticResource PrimaryColor}" 
            Style="{StaticResource ModernButton}" Click="Refresh_Click"/>
                        <Button Content="🚪 Выйти" Background="{StaticResource ErrorColor}" 
            Style="{StaticResource ModernButton}" Click="Logout_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Вкладки файлов и редактор -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabControl x:Name="FileTabs" Grid.Row="0" TabStripPlacement="Top"
                            SelectionChanged="FileTab_SelectionChanged"
                            Background="{StaticResource BackgroundLight}" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem" BasedOn="{StaticResource TabItemStyle}"/>
                    </TabControl.ItemContainerStyle>
                </TabControl>

                <Border Grid.Row="1" Style="{StaticResource CodeEditorBorderStyle}">
                    <controls:SyntaxHighlightingTextBox x:Name="CodeEditor"/>
                </Border>
            </Grid>

            <!-- Разделитель -->
            <GridSplitter Grid.Row="2" Style="{StaticResource GridSplitterStyle}" ResizeDirection="Rows"/>

            <!-- Нижняя панель - вывод -->
            <Border Grid.Row="3" Background="{StaticResource BackgroundDark}" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource BackgroundMedium}" Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📋 ВЫВОД ПРОГРАММЫ" 
                                       Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold"/>

                            <TextBlock Grid.Column="1" x:Name="OutputInfoText" 
                                       Text="" Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="15,0,0,0"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="📋 Копировать" Background="{StaticResource BackgroundLight}" 
                                        Style="{StaticResource SmallButton}" Click="CopyOutput_Click"/>
                                <Button Content="🗑 Очистить" Background="{StaticResource BackgroundLight}" 
                                        Style="{StaticResource SmallButton}" Click="ClearOutput_Click" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBox x:Name="OutputBox" Background="{StaticResource BackgroundDark}" 
                             Foreground="{StaticResource TextPrimary}" 
                             FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" IsReadOnly="True"
                             BorderThickness="0" Padding="10" 
                             Text="✨ Добро пожаловать в SimpleIDE для IAS-2025! ✨"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>