<Window x:Class="SimpleIDE.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleIDE - Вход" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="/images/logo.png"
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель с брендом -->
        <Border Grid.Column="0" Background="#6C63FF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <TextBlock Text="SimpleIDE" FontSize="42" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Лучшая среда разработки" FontSize="18" Foreground="#E0E0E0" Margin="0,10,0,0"/>
                <Border Height="2" Width="50" Background="#FF6584" Margin="0,20,0,0"/>
                <TextBlock Text="Пишите, компилируйте и управляйте" 
                           FontSize="14" Foreground="#E0E0E0" Margin="0,20,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="своими проектами в одном месте" 
                           FontSize="14" Foreground="#E0E0E0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Правая панель с формами -->
        <Border Grid.Column="1" Background="White">
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock x:Name="TitleText" Text="Вход" FontSize="28" FontWeight="SemiBold" 
                           Foreground="#333" Margin="0,0,0,30"/>

                <!-- Форма входа/регистрации -->
                <StackPanel Grid.Row="1">
                    <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}"
         Margin="0,0,0,20" Text=""
         VerticalContentAlignment="Center"/>

                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}"
             Margin="0,0,0,20"
             VerticalContentAlignment="Center"/>

                    <Button x:Name="ActionButton" Content="Войти" 
                            Background="#6C63FF" Foreground="White"
                            Style="{StaticResource ModernButton}"
                            FontSize="16" Height="45"
                            Click="ActionButton_Click"/>

                    <TextBlock x:Name="ToggleText" Text="Нет аккаунта? Зарегистрироваться" 
                               TextAlignment="Center" Margin="0,15,0,0" Cursor="Hand"
                               Foreground="#6C63FF" TextDecorations="Underline"
                               MouseLeftButtonDown="ToggleMode_Click"/>

                    <TextBlock x:Name="MessageText" Text="" Foreground="#F44336" 
                               Margin="0,10,0,0" TextAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>