    <SolidColorBrush x:Key="PrimaryLight" Color="#D6ACFF"/>
    <SolidColorBrush x:Key="AccentColor" Color="#50FA7B"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFB86C"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#FF5555"/>
    <SolidColorBrush x:Key="AdminColor" Color="#FF79C6"/>
