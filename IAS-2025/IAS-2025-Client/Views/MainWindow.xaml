<Window x:Class="IAS_2025_Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:IAS_2025_Client.ViewModels"
        Title="IAS-2025 IDE" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MaterialDesignBackground}">

    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="False"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>

        <DataTemplate x:Key="FileTreeNodeTemplate">
            <StackPanel Orientation="Horizontal">
                <material:PackIcon Kind="{Binding Type, Converter={StaticResource TypeToIconConverter}}"
                                  Width="16" Height="16" Margin="0,0,5,0"
                                  Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:FileTreeNode}"
                                  ItemsSource="{Binding Children}"
                                  ItemTemplate="{StaticResource FileTreeNodeTemplate}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource FileTreeNodeTemplate}"/>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - File Explorer -->
        <Border Grid.Column="0" Background="#1E1E2E" BorderBrush="#2A2A3E" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#252536" Padding="15,12">
                    <StackPanel>
                        <TextBlock Text="FILE EXPLORER" FontSize="12" 
                                   Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                                   FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Command="{Binding NewFileCommand}" Style="{StaticResource MaterialDesignToolButton}"
                                    ToolTip="New File" Margin="0,0,5,0" Cursor="Hand">
                                <material:PackIcon Kind="FilePlus" Width="18" Height="18"/>
                            </Button>
                            <Button Command="{Binding NewFolderCommand}" Style="{StaticResource MaterialDesignToolButton}"
                                    ToolTip="New Folder" Margin="0,0,5,0" Cursor="Hand">
                                <material:PackIcon Kind="FolderPlus" Width="18" Height="18"/>
                            </Button>
                            <Button Command="{Binding DeleteItemCommand}" Style="{StaticResource MaterialDesignToolButton}"
                                    ToolTip="Delete" Cursor="Hand">
                                <material:PackIcon Kind="Delete" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- TreeView -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TreeView x:Name="FileTreeView" ItemsSource="{Binding FileTree}"
                             Background="Transparent" BorderThickness="0"
                             SelectedItemChanged="FileTreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Center Panel - Code Editor -->
        <Border Grid.Column="1" Background="#1A1A2E">
            <DockPanel>
                <!-- Toolbar -->
                <Border DockPanel.Dock="Top" Background="#252536" Padding="15,12">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIcon Kind="LanguageCsharp" Width="20" Height="20"
                                          Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"
                                          Margin="0,0,10,0"/>
                        <TextBlock Text="CODE EDITOR" FontSize="12" 
                                   Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Rectangle Width="1" Height="20" Fill="#3A3A4E" Margin="15,0"/>
                        <Button Command="{Binding SaveFileCommand}" Style="{StaticResource MaterialDesignFlatButton}"
                                Cursor="Hand" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <material:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,5,0"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RunCodeCommand}" Style="{StaticResource MaterialDesignFlatButton}"
                                Cursor="Hand" Background="{StaticResource MaterialDesignPrimaryHueLightBrush}"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal">
                                <material:PackIcon Kind="Play" Width="18" Height="18" Margin="0,0,5,0"/>
                                <TextBlock Text="Run Code (F5)"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Code Editor -->
                <TextBox x:Name="CodeEditor" Text="{Binding CurrentCode, UpdateSourceTrigger=PropertyChanged}"
                         Background="#0D1117" Foreground="#E6EDF3" 
                         BorderThickness="0" FontFamily="Consolas" FontSize="13"
                         AcceptsReturn="True" AcceptsTab="True" 
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         Padding="15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Loading Overlay -->
                <Border x:Name="LoadingOverlay" Background="#CC1A1A2E" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <material:ProgressRing IsActive="True" Width="60" Height="60"
                                              Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"/>
                        <TextBlock Text="Executing code..." Margin="0,15,0,0" Foreground="White"
                                   FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Right Panel - Output -->
        <Border Grid.Column="2" Background="#1E1E2E" BorderBrush="#2A2A3E" BorderThickness="1,0,0,0">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#252536" Padding="15,12">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIcon Kind="Console" Width="20" Height="20"
                                          Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"
                                          Margin="0,0,10,0"/>
                        <TextBlock Text="OUTPUT" FontSize="12" 
                                   Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Rectangle Width="1" Height="20" Fill="#3A3A4E" Margin="15,0"/>
                        <Button Command="{Binding RunCodeCommand}" Style="{StaticResource MaterialDesignToolButton}"
                                ToolTip="Clear Output" Cursor="Hand" Margin="0,0,5,0">
                            <material:PackIcon Kind="Eraser" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Output Display -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D1117">
                    <TextBox x:Name="OutputBox" Text="{Binding Output}" 
                             Background="#0D1117" Foreground="#E6EDF3"
                             BorderThickness="0" FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Padding="15"
                             MinHeight="200"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Admin Panel (hidden by default) -->
        <Border x:Name="AdminPanel" Grid.Column="2" Background="#1E1E2E" Width="350"
                HorizontalAlignment="Right" Visibility="Collapsed">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#252536" Padding="15,12">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIcon Kind="ShieldAccount" Width="20" Height="20"
                                          Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"
                                          Margin="0,0,10,0"/>
                        <TextBlock Text="USER MANAGEMENT" FontSize="12" 
                                   Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Command="{Binding RefreshUsersCommand}" Style="{StaticResource MaterialDesignToolButton}"
                                Cursor="Hand" Margin="10,0,0,0">
                            <material:PackIcon Kind="Refresh" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding Users}" Background="#0D1117" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" BorderBrush="#252536" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Username}" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding Email}" FontSize="11" 
                                                   Foreground="{StaticResource MaterialDesignBodyLightBrush}"/>
                                        <TextBlock Text="{Binding IsAdmin, Converter={StaticResource AdminStatusConverter}}"
                                                   FontSize="10" Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Command="{Binding DataContext.MakeUserAdminCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Cursor="Hand"
                                            Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVisibility}}"
                                            Style="{StaticResource MaterialDesignFlatButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <material:PackIcon Kind="ShieldPlus" Width="16" Height="16" Margin="0,0,5,0"/>
                                            <TextBlock Text="Make Admin" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Top Bar -->
        <Border Grid.ColumnSpan="3" Height="35" VerticalAlignment="Top" Background="#1A1A2E" Opacity="0.95">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,15,0">
                    <Button x:Name="AdminButton" Content="👑 ADMIN" Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                            FontSize="12" Margin="0,0,10,0"/>
                    <Button x:Name="LogoutButton" Content="🚪 LOGOUT" Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                            FontSize="12"/>
                </StackPanel>
                <TextBlock Text="IAS-2025 Development Environment" VerticalAlignment="Center"
                           Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                           FontSize="11" Margin="15,0,0,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>