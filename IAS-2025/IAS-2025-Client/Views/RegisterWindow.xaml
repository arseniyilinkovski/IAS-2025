<Window x:Class="IAS_2025_Client.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="IAS-2025 IDE - Register" Height="550" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="15">
        <Border.Background>
            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Create Account" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"
                       HorizontalAlignment="Center" Margin="0,20,0,10"/>

            <TextBlock Grid.Row="1" Text="Join the IAS-2025 community" FontSize="14"
                       Foreground="{StaticResource MaterialDesignBodyLightBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBox x:Name="UsernameBox" Grid.Row="2" material:HintAssist.Hint="Username"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     Margin="0,10" FontSize="14" Height="50"/>

            <TextBox x:Name="EmailBox" Grid.Row="3" material:HintAssist.Hint="Email"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     Margin="0,10" FontSize="14" Height="50"/>

            <PasswordBox x:Name="PasswordBox" Grid.Row="4" material:HintAssist.Hint="Password (min 6 chars)"
                         Style="{StaticResource MaterialDesignFilledPasswordBox}"
                         Margin="0,10" FontSize="14" Height="50"/>

            <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="5" material:HintAssist.Hint="Confirm Password"
                         Style="{StaticResource MaterialDesignFilledPasswordBox}"
                         Margin="0,10" FontSize="14" Height="50"/>

            <Button x:Name="RegisterButton" Grid.Row="6" Content="REGISTER"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource MaterialDesignPrimaryHueLightBrush}"
                    Foreground="White" FontWeight="Bold" Height="45"
                    Margin="0,20,0,10" Cursor="Hand"/>

            <Border x:Name="LoadingOverlay" Grid.RowSpan="7" Background="#CC1a1a2e"
                    Visibility="Collapsed" CornerRadius="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <material:ProgressRing IsActive="True" Width="50" Height="50"
                                          Foreground="{StaticResource MaterialDesignPrimaryHueLightBrush}"/>
                    <TextBlock Text="Creating account..." Margin="0,10,0,0"
                               Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>